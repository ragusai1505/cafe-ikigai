# ─────────────────────────────────────────────────────────────────
# Cafe Ikigai — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# Firebase Configuration (get from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: Anthropic API (for AI-powered chatbot upgrade)
# VITE_ANTHROPIC_API_KEY=your_anthropic_key

# ─────────────────────────────────────────────────────────────────
# NOTE: The app works WITHOUT Firebase using localStorage.
# Firebase is only needed if you want cloud sync across devices.
# ─────────────────────────────────────────────────────────────────
